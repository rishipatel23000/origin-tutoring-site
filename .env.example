# Copy this file to .env.local and fill in real values.
# .env.local is gitignored -- never commit real keys.
# See SETUP.md for exactly where each value comes from.

# Supabase project settings -> API
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe dashboard -> Developers -> API keys
STRIPE_SECRET_KEY=

# Stripe dashboard -> Developers -> Webhooks (or `stripe listen` for local dev)
STRIPE_WEBHOOK_SECRET=

# Your site's base URL -- used to build Stripe success/cancel redirect URLs.
# Local dev: http://localhost:3000
# Production: your real domain, e.g. https://origintutoring.com
NEXT_PUBLIC_SITE_URL=
